{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-workflow-lab/schemas/tool-policy.schema.json",
  "title": "ToolPolicy",
  "type": "object",
  "required": [
    "version",
    "defaults",
    "rules",
    "forbidden_patterns",
    "approval_required_tools"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "defaults": {
      "type": "object",
      "required": ["read_only_allowed", "write_requires_approval", "external_write_allowed"],
      "additionalProperties": false,
      "properties": {
        "read_only_allowed": { "type": "boolean" },
        "write_requires_approval": { "type": "boolean" },
        "external_write_allowed": { "type": "boolean" },
        "shell_execution_requires_justification": { "type": "boolean" }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "effect"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "effect": {
            "type": "string",
            "enum": ["allow", "deny", "require_approval"]
          },
          "tools": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conditions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "forbidden_patterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "approval_required_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
