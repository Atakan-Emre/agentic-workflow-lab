{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-workflow-lab/schemas/agent-manifest.schema.json",
  "title": "AgentManifest",
  "type": "object",
  "required": [
    "name",
    "role",
    "goal",
    "allowed_tools",
    "blocked_tools",
    "input_contract",
    "output_contract",
    "handoff_targets",
    "approval_required_when",
    "risk_level",
    "quality_gates"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "blocked_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "input_contract": {
      "type": "object",
      "required": ["description", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "required_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "optional_fields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "output_contract": {
      "type": "object",
      "required": ["description", "artifacts"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "handoff_targets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "approval_required_when": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "quality_gates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
